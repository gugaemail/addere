node_modules
dist
.expo

# Variáveis de ambiente — nunca commitar valores reais
# Padrão cobre todos os projetos do monorepo (apps/api, apps/web, apps/mobile)
.env
.env.local
.env.development
.env.staging
.env.production
# .env.example e .env.local.example são commitados intencionalmente

# Credenciais de lojas — nunca commitar
apps/mobile/google-service-account.json

# Build outputs
apps/web/.next/
apps/web/out/
apps/web/next-env.d.ts
*.tsbuildinfo

# Compiled package outputs (gerados por tsc)
packages/*/src/*.js
packages/*/src/*.js.map
packages/*/src/*.d.ts
packages/*/src/*.d.ts.map

# IDE e ferramentas locais
.vscode/
.claude/
.npmrc

# Logs
*.log
npm-debug.log*
