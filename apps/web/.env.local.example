# URL da API backend consumida pelo painel admin
# Copie este arquivo para .env.local e ajuste os valores
NEXT_PUBLIC_API_URL=http://localhost:3333

# DSN do Sentry para rastreamento de erros no admin
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz

# Identificador do ambiente (development | staging | production)
APP_ENV=development
