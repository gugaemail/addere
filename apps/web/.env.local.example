# URL da API backend consumida pelo painel admin
# Copie este arquivo para .env.local e ajuste os valores
NEXT_PUBLIC_API_URL=http://localhost:3333

# URL pública do painel admin (usada no link do email de relatório semanal)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# DSN do Sentry para rastreamento de erros no admin
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz

# Identificador do ambiente (development | staging | production)
APP_ENV=development

# ─── Piloto comercial ──────────────────────────────────────────────────────

# Resend — envio de email do relatório semanal de piloto
# Gerar em: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Segredo para proteger o endpoint de cron (/api/cron/weekly-report)
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=change-me-cron-secret

# URL do banco PostgreSQL (necessária para as API Routes Next.js acessarem Prisma)
# Mesma DATABASE_URL da API
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DATABASE_URL_DIRECT="postgresql://user:password@host/dbname?sslmode=require"
