NEXT_PUBLIC_API_URL=http://localhost:3333

# URL pública do painel admin (usada no link do email de relatório semanal)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend — envio de email do relatório semanal de piloto
# Gerar em: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Segredo para proteger o endpoint de cron (/api/cron/weekly-report)
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Configurar também em: Vercel Dashboard → Project Settings → Cron Job Secret
CRON_SECRET=change-me-cron-secret

# Mesmo JWT_SECRET usado pela API — necessário para o middleware verificar tokens nas rotas Next.js
# NUNCA prefixar com NEXT_PUBLIC_ (segredo server-only)
JWT_SECRET=change-me-jwt-secret
