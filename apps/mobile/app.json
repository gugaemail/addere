{
  "expo": {
    "name": "Addere",
    "slug": "addere",
    "version": "1.0.0",
    "scheme": "addere",
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sqlite"
    ],
    "splash": {
      "backgroundColor": "#0D2045",
      "resizeMode": "contain"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D2045"
      }
    },
    "ios": {
      "bundleIdentifier": "com.addere.app"
    }
  }
}
