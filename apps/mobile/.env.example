# URL da API backend — ajuste para o IP/domínio do seu ambiente
EXPO_PUBLIC_API_URL=http://localhost:3333

# URL direta do servidor Protheus (REST)
EXPO_PUBLIC_PROTHEUS_URL=http://localhost:8080

# DSN do Sentry para rastreamento de erros — obrigatório em todos os ambientes
EXPO_PUBLIC_SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz

# Identificador do ambiente (development | staging | production)
EXPO_PUBLIC_APP_ENV=development

# Versão do app no formato SemVer — deve corresponder ao version no app.config.js
EXPO_PUBLIC_APP_VERSION=1.0.0
