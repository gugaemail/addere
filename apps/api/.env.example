# Neon — connection pooler (pgBouncer) — usado pela aplicação
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Neon — conexão direta — usado pelo Prisma CLI (migrate, introspect, studio)
DATABASE_URL_DIRECT="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

JWT_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"

# Chave de 64 chars hex (32 bytes) para criptografar credenciais Protheus
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PROTHEUS_ENCRYPTION_KEY=""  # OBRIGATÓRIO: gere com: openssl rand -hex 32

NODE_ENV="development"
PORT="3333"
CORS_ORIGIN="http://localhost:3000"

# E-mail de recuperação de senha (Resend — https://resend.com)
RESEND_API_KEY=""

# URL do painel web (usada no link do e-mail de reset)
WEB_URL="https://addere-web.vercel.app"

# Pasta local para screenshots dos reportes da Central de Ajuda
UPLOAD_DIR=uploads
