// Prisma schema — Addere ERP Mobile
// Banco: PostgreSQL | ORM: Prisma 5

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_DIRECT")
}

// ─────────────────────────────────────────
// Enums
// ─────────────────────────────────────────

enum Role {
  SUPERADMIN  // administrador da plataforma (painel web)
  ADMIN       // administrador da empresa (app mobile)
  SALESPERSON // vendedor (app mobile)
}

enum OrderStatus {
  PENDING    // criado localmente, aguardando sincronização
  SYNCED     // enviado com sucesso ao Protheus
  CANCELLED
}

// ─────────────────────────────────────────
// Company — empresas (tenants)
// ─────────────────────────────────────────

model Company {
  id          String  @id @default(uuid())
  name        String
  cnpj        String  @unique
  idProtheus  String? // código da empresa no ERP Protheus
  active      Boolean @default(true)

  // URLs das APIs Protheus configuradas por empresa
  apiToken     String? // POST autenticação — retorna Bearer token
  apiPord      String? // GET produtos
  apiCliente   String? // GET clientes
  apiMetaVend  String? // GET metas de vendedor
  apiPedido    String? // POST pedido
  apiConsPed   String? // GET consulta pedido
  apiCondPag   String? // GET condições de pagamento
  apiTransp    String? // GET transportadoras
  usrProtheus  String? // usuário para autenticação na API Protheus
  passProtheus String? // senha para autenticação na API Protheus
  syncConfig   Json?   // mapeamento de campos Protheus por entidade (JSONB)
  fieldConfig  Json?   // visibilidade de campos por empresa: { hidden: string[] }
  syncSchedule Json?   // agendamento de sync: { products: {...}, customers: {...} }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches        Branch[]
  users           User[]
  customers       Customer[]
  products        Product[]
  orders          Order[]
  transportadoras Transportadora[]
  condPags        CondPag[]

  @@map("companies")
}

// ─────────────────────────────────────────
// Branch — filiais de uma empresa
// ─────────────────────────────────────────

model Branch {
  id         String  @id @default(uuid())
  name       String
  cnpj       String?
  idProtheus String? // código da filial no ERP Protheus
  active     Boolean @default(true)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@map("branches")
}

// ─────────────────────────────────────────
// User — vendedores e administradores
// ─────────────────────────────────────────

model User {
  id          String  @id @default(uuid())
  name        String
  email       String  @unique
  password    String
  role        Role    @default(SALESPERSON)
  active      Boolean @default(true) // soft delete
  idVendProt  String? // código do vendedor no Protheus

  // null para SUPERADMIN; obrigatório para ADMIN e SALESPERSON
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens RefreshToken[]
  orders        Order[]

  @@map("users")
}

// ─────────────────────────────────────────
// RefreshToken — tokens de renovação JWT
// ─────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ─────────────────────────────────────────
// Customer — clientes dos vendedores
// ─────────────────────────────────────────

model Customer {
  id           String  @id @default(uuid())
  protheusCode String? // código do cliente no ERP Protheus
  loja         String? // código da loja (chave composta com protheusCode)
  vendorCode   String? // código do vendedor responsável (A1_VEND no Protheus)
  name         String
  document     String? // CPF ou CNPJ (único por empresa)
  email        String?
  phone        String?
  address      String?
  municipio    String?
  bairro       String?
  cep          String?
  uf           String?
  ultcom       DateTime? // data da última compra no Protheus (A1_ULTCOM)
  msblql       String?   // A1_MSBLQL: "1"=bloqueado, "2"=liberado — inativa cliente se "1"
  transpPadrao String?   // A1_TRANSP: código da transportadora padrão do cliente
  condPagPadrao String?  // A1_COND: código da condição de pagamento padrão do cliente
  tes          String?   // A1_TES: código TES (enviado ao Protheus no pedido)
  xcodemp      String?   // A1_XCODEMP: código da filial Protheus de faturamento
  active       Boolean @default(true) // soft delete

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@unique([companyId, loja, protheusCode])
  @@unique([companyId, document])
  @@index([companyId, active])
  @@index([companyId, name])
  @@map("customers")
}

// ─────────────────────────────────────────
// Product — catálogo de produtos por empresa
// ─────────────────────────────────────────

model Product {
  id           String  @id @default(uuid())
  protheusCode String? // código do produto no ERP Protheus (único por empresa)
  name         String
  description  String?
  price        Decimal @db.Decimal(10, 2)
  unit         String  @default("UN") // unidade de medida
  stock        Decimal @default(0) @db.Decimal(10, 3)
  saldo        Decimal @default(0) @db.Decimal(10, 2) // saldo disponível
  active       Boolean @default(true) // soft delete

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]

  @@unique([companyId, protheusCode])
  @@index([companyId, active])
  @@index([companyId, name])
  @@map("products")
}

// ─────────────────────────────────────────
// Transportadora
// ─────────────────────────────────────────

model Transportadora {
  id           String  @id @default(uuid())
  protheusCode String?
  nome         String

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  orders Order[]

  @@unique([companyId, protheusCode])
  @@map("transportadoras")
}

// ─────────────────────────────────────────
// CondPag — condições de pagamento
// ─────────────────────────────────────────

model CondPag {
  id           String  @id @default(uuid())
  protheusCode String?
  nome         String

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  orders Order[]

  @@unique([companyId, protheusCode])
  @@map("cond_pags")
}

// ─────────────────────────────────────────
// Order — pedidos de venda
// ─────────────────────────────────────────

model Order {
  id              String      @id @default(uuid())
  status          OrderStatus @default(PENDING)
  total           Decimal     @db.Decimal(10, 2)
  notes           String?
  protheusOrderId String?     @unique // ID do pedido no ERP após sincronização
  protheusStatus  String?               // último status consultado no Protheus
  syncedAt        DateTime?   // data/hora da sincronização com o Protheus
  emissao         DateTime?   // data de criação do pedido (informada pelo usuário)
  mennota         String?     // mensagem para nota fiscal

  userId String
  user   User   @relation(fields: [userId], references: [id])

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  transportId String?
  transportadora Transportadora? @relation(fields: [transportId], references: [id])

  condId String?
  condPag CondPag? @relation(fields: [condId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OrderItem[]

  @@index([userId, companyId])
  @@index([companyId, status])
  @@map("orders")
}

// ─────────────────────────────────────────
// OrderItem — itens do pedido
// ─────────────────────────────────────────

model OrderItem {
  id        String  @id @default(uuid())
  quantity  Decimal @db.Decimal(10, 3)
  unitPrice Decimal @db.Decimal(10, 2)
  discount  Decimal @default(0) @db.Decimal(5, 2) // percentual de desconto
  total     Decimal @db.Decimal(10, 2)
  descricao    String?           // descrição do item (sobrescreve nome do produto se informado)
  largura      Decimal? @db.Decimal(10, 3) // C6_XLARGUR
  espessura    Decimal? @db.Decimal(10, 3) // C6_XEXPESS
  encolhimento String?           // C6_XENCOLH
  xcrav        String?           // C6_XCRAV: "1"=Sim, "2"=Não
  tara         Decimal? @db.Decimal(10, 3) // C6_XTARA

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())

  @@map("order_items")
}
