// Prisma schema — Addere ERP Mobile
// Banco: PostgreSQL | ORM: Prisma 5

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// Enums
// ─────────────────────────────────────────

enum Role {
  SUPERADMIN  // administrador da plataforma (painel web)
  ADMIN       // administrador da empresa (app mobile)
  SALESPERSON // vendedor (app mobile)
}

enum OrderStatus {
  PENDING    // criado localmente, aguardando sincronização
  SYNCED     // enviado com sucesso ao Protheus
  CANCELLED
}

// ─────────────────────────────────────────
// Company — empresas (tenants)
// ─────────────────────────────────────────

model Company {
  id          String  @id @default(uuid())
  name        String
  cnpj        String  @unique
  idProtheus  String? // código da empresa no ERP Protheus
  active      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches  Branch[]
  users     User[]
  customers Customer[]
  products  Product[]
  orders    Order[]

  @@map("companies")
}

// ─────────────────────────────────────────
// Branch — filiais de uma empresa
// ─────────────────────────────────────────

model Branch {
  id         String  @id @default(uuid())
  name       String
  cnpj       String?
  idProtheus String? // código da filial no ERP Protheus
  active     Boolean @default(true)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@map("branches")
}

// ─────────────────────────────────────────
// User — vendedores e administradores
// ─────────────────────────────────────────

model User {
  id        String  @id @default(uuid())
  name      String
  email     String  @unique
  password  String
  role      Role    @default(SALESPERSON)
  active    Boolean @default(true) // soft delete

  // null para SUPERADMIN; obrigatório para ADMIN e SALESPERSON
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens RefreshToken[]
  orders        Order[]

  @@map("users")
}

// ─────────────────────────────────────────
// RefreshToken — tokens de renovação JWT
// ─────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ─────────────────────────────────────────
// Customer — clientes dos vendedores
// ─────────────────────────────────────────

model Customer {
  id           String  @id @default(uuid())
  protheusCode String? // código do cliente no ERP Protheus (único por empresa)
  name         String
  document     String? // CPF ou CNPJ (único por empresa)
  email        String?
  phone        String?
  address      String?
  active       Boolean @default(true) // soft delete

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@unique([companyId, protheusCode])
  @@unique([companyId, document])
  @@map("customers")
}

// ─────────────────────────────────────────
// Product — catálogo de produtos por empresa
// ─────────────────────────────────────────

model Product {
  id           String  @id @default(uuid())
  protheusCode String? // código do produto no ERP Protheus (único por empresa)
  name         String
  description  String?
  price        Decimal @db.Decimal(10, 2)
  unit         String  @default("UN") // unidade de medida
  stock        Decimal @default(0) @db.Decimal(10, 3)
  active       Boolean @default(true) // soft delete

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]

  @@unique([companyId, protheusCode])
  @@map("products")
}

// ─────────────────────────────────────────
// Order — pedidos de venda
// ─────────────────────────────────────────

model Order {
  id              String      @id @default(uuid())
  status          OrderStatus @default(PENDING)
  total           Decimal     @db.Decimal(10, 2)
  notes           String?
  protheusOrderId String?     @unique // ID do pedido no ERP após sincronização
  syncedAt        DateTime?   // data/hora da sincronização com o Protheus

  userId String
  user   User   @relation(fields: [userId], references: [id])

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OrderItem[]

  @@map("orders")
}

// ─────────────────────────────────────────
// OrderItem — itens do pedido
// ─────────────────────────────────────────

model OrderItem {
  id        String  @id @default(uuid())
  quantity  Decimal @db.Decimal(10, 3)
  unitPrice Decimal @db.Decimal(10, 2)
  discount  Decimal @default(0) @db.Decimal(5, 2) // percentual de desconto
  total     Decimal @db.Decimal(10, 2)

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())

  @@map("order_items")
}
