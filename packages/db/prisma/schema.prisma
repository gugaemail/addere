// Prisma schema — Addere ERP Mobile
// Banco: PostgreSQL | ORM: Prisma 5

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// Enums
// ─────────────────────────────────────────

enum Role {
  ADMIN
  SALESPERSON
}

enum OrderStatus {
  PENDING    // criado localmente, aguardando sincronização
  SYNCED     // enviado com sucesso ao Protheus
  CANCELLED
}

// ─────────────────────────────────────────
// User — vendedores e administradores
// ─────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(SALESPERSON)
  active    Boolean  @default(true) // soft delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens RefreshToken[]
  orders        Order[]

  @@map("users")
}

// ─────────────────────────────────────────
// RefreshToken — tokens de renovação JWT
// ─────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ─────────────────────────────────────────
// Customer — clientes dos vendedores
// ─────────────────────────────────────────

model Customer {
  id           String  @id @default(uuid())
  protheusCode String? @unique // código do cliente no ERP Protheus
  name         String
  document     String? @unique // CPF ou CNPJ
  email        String?
  phone        String?
  address      String?
  active       Boolean @default(true) // soft delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@map("customers")
}

// ─────────────────────────────────────────
// Product — catálogo de produtos
// ─────────────────────────────────────────

model Product {
  id           String  @id @default(uuid())
  protheusCode String? @unique // código do produto no ERP Protheus
  name         String
  description  String?
  price        Decimal @db.Decimal(10, 2)
  unit         String  @default("UN") // unidade de medida
  stock        Decimal @default(0) @db.Decimal(10, 3)
  active       Boolean @default(true) // soft delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]

  @@map("products")
}

// ─────────────────────────────────────────
// Order — pedidos de venda
// ─────────────────────────────────────────

model Order {
  id              String      @id @default(uuid())
  status          OrderStatus @default(PENDING)
  total           Decimal     @db.Decimal(10, 2)
  notes           String?
  protheusOrderId String?     @unique // ID do pedido no ERP após sincronização
  syncedAt        DateTime?   // data/hora da sincronização com o Protheus

  userId     String
  user       User     @relation(fields: [userId], references: [id])

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OrderItem[]

  @@map("orders")
}

// ─────────────────────────────────────────
// OrderItem — itens do pedido
// ─────────────────────────────────────────

model OrderItem {
  id        String  @id @default(uuid())
  quantity  Decimal @db.Decimal(10, 3)
  unitPrice Decimal @db.Decimal(10, 2)
  discount  Decimal @default(0) @db.Decimal(5, 2) // percentual de desconto
  total     Decimal @db.Decimal(10, 2)

  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())

  @@map("order_items")
}
