# Neon — connection pooler (pgBouncer) — usado pela aplicação
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Neon — conexão direta — usado pelo Prisma CLI (migrate, introspect, studio)
DATABASE_URL_DIRECT="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# Segredos JWT — use strings longas e aleatórias em produção (ex: openssl rand -base64 64)
JWT_SECRET="your-access-token-secret-change-in-production"
JWT_REFRESH_SECRET="your-refresh-token-secret-change-in-production"

# Chave de criptografia das credenciais Protheus (AES-256-GCM)
# Deve ter exatamente 64 caracteres hex (32 bytes). Gere com: openssl rand -hex 32
PROTHEUS_ENCRYPTION_KEY=""  # OBRIGATÓRIO: gere com: openssl rand -hex 32

# Ambiente da aplicação (development | test | production)
NODE_ENV="development"

# Porta do servidor Fastify
PORT="3333"

# Origem permitida no CORS (URL do frontend)
CORS_ORIGIN="http://localhost:3000"

# URL pública da API consumida pelo app Expo (prefixo EXPO_PUBLIC_ obrigatório)
EXPO_PUBLIC_API_URL="http://localhost:3333"
